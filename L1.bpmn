<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://bpmn.io/schema/bpmn"
             id="Definitions_L1">

  <collaboration id="Collab_L1">
    <participant id="Pool_Company" name="Компания (Платформа для управления проектами)" processRef="Process_L1"/>
    <participant id="Pool_Client"  name="Клиент" processRef="Process_Client"/>
    <!-- message flow: клиент → стартовое событие -->
    <messageFlow id="MF_in"  sourceRef="Ev_ClientSend"   targetRef="Ev_Start"/>
    <!-- message flow: задача-отправка → событие клиента -->
    <messageFlow id="MF_out" sourceRef="Task_Notify"      targetRef="Ev_ClientReceive"/>
  </collaboration>

  <!-- ===== КЛИЕНТ (свёрнутый пул) ===== -->
  <process id="Process_Client" isExecutable="false">
    <startEvent id="Ev_ClientSend" name="Клиент отправляет заявку">
      <messageEventDefinition/>
    </startEvent>
    <endEvent id="Ev_ClientReceive" name="Клиент получает ответ">
      <messageEventDefinition/>
    </endEvent>
    <sequenceFlow id="SF_Cl1" sourceRef="Ev_ClientSend" targetRef="Ev_ClientReceive"/>
  </process>

  <!-- ===== КОМПАНИЯ ===== -->
  <process id="Process_L1" isExecutable="false" name="L1: Обработка входящей заявки клиента">

    <laneSet id="LaneSet_L1">
      <lane id="Lane_Op" name="Оператор">
        <flowNodeRef>Ev_Start</flowNodeRef>
        <flowNodeRef>Task_Register</flowNodeRef>
        <flowNodeRef>Task_Classify</flowNodeRef>
        <flowNodeRef>GW_Type</flowNodeRef>
        <flowNodeRef>Task_Process</flowNodeRef>
        <flowNodeRef>Task_Escalate</flowNodeRef>
        <flowNodeRef>GW_Merge</flowNodeRef>
        <flowNodeRef>Task_Approve</flowNodeRef>
        <flowNodeRef>GW_Approved</flowNodeRef>
        <flowNodeRef>Task_Rework</flowNodeRef>
        <flowNodeRef>Task_Notify</flowNodeRef>
        <flowNodeRef>Ev_End</flowNodeRef>
      </lane>
    </laneSet>

    <!-- START: получение сообщения -->
    <startEvent id="Ev_Start" name="Заявка получена">
      <messageEventDefinition/>
    </startEvent>

    <!-- Задачи (пользовательские) -->
    <userTask id="Task_Register" name="Зарегистрировать заявку"/>
    <userTask id="Task_Classify"  name="Классифицировать заявку"/>

    <!-- XOR: тип заявки -->
    <exclusiveGateway id="GW_Type" name="Тип заявки?"/>

    <userTask id="Task_Process"  name="Обработать заявку"/>
    <userTask id="Task_Escalate" name="Передать на эскалацию"/>

    <!-- XOR: слияние -->
    <exclusiveGateway id="GW_Merge" name=""/>

    <userTask id="Task_Approve" name="Согласовать решение"/>

    <!-- XOR: согласовано? -->
    <exclusiveGateway id="GW_Approved" name="Согласовано?"/>

    <userTask id="Task_Rework" name="Доработать решение"/>

    <!-- Задача-отправка сообщения -->
    <sendTask id="Task_Notify" name="Уведомить клиента"/>

    <!-- END: конечное событие — ПОСЛЕ уведомления -->
    <endEvent id="Ev_End" name="Заявка закрыта"/>

    <!-- SEQUENCE FLOWS -->
    <sequenceFlow id="SF1"  sourceRef="Ev_Start"      targetRef="Task_Register"/>
    <sequenceFlow id="SF2"  sourceRef="Task_Register"  targetRef="Task_Classify"/>
    <sequenceFlow id="SF3"  sourceRef="Task_Classify"  targetRef="GW_Type"/>
    <sequenceFlow id="SF4"  sourceRef="GW_Type"        targetRef="Task_Process"  name="Стандартная"/>
    <sequenceFlow id="SF5"  sourceRef="GW_Type"        targetRef="Task_Escalate" name="Требует эскалации"/>
    <sequenceFlow id="SF6"  sourceRef="Task_Process"   targetRef="GW_Merge"/>
    <sequenceFlow id="SF7"  sourceRef="Task_Escalate"  targetRef="GW_Merge"/>
    <sequenceFlow id="SF8"  sourceRef="GW_Merge"       targetRef="Task_Approve"/>
    <sequenceFlow id="SF9"  sourceRef="Task_Approve"   targetRef="GW_Approved"/>
    <sequenceFlow id="SF10" sourceRef="GW_Approved"    targetRef="Task_Notify"   name="Да"/>
    <sequenceFlow id="SF11" sourceRef="GW_Approved"    targetRef="Task_Rework"   name="Нет"/>
    <sequenceFlow id="SF12" sourceRef="Task_Rework"    targetRef="Task_Approve"/>
    <!-- Task_Notify → Ev_End (конечное событие ПОСЛЕ уведомления) -->
    <sequenceFlow id="SF13" sourceRef="Task_Notify"    targetRef="Ev_End"/>
  </process>

  <!-- ===== DIAGRAM (DI) ===== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_L1">
    <bpmndi:BPMNPlane id="BPMNPlane_L1" bpmnElement="Collab_L1">

      <!-- POOL: Компания -->
      <bpmndi:BPMNShape id="Shape_Pool_Company" bpmnElement="Pool_Company" isHorizontal="true">
        <dc:Bounds x="150" y="80"  width="1450" height="340"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Op" bpmnElement="Lane_Op" isHorizontal="true">
        <dc:Bounds x="180" y="80"  width="1420" height="340"/>
      </bpmndi:BPMNShape>

      <!-- START -->
      <bpmndi:BPMNShape id="Shape_Ev_Start" bpmnElement="Ev_Start">
        <dc:Bounds x="222" y="232" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="200" y="273" width="80" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- T1 -->
      <bpmndi:BPMNShape id="Shape_Task_Register" bpmnElement="Task_Register">
        <dc:Bounds x="310" y="210" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- T2 -->
      <bpmndi:BPMNShape id="Shape_Task_Classify" bpmnElement="Task_Classify">
        <dc:Bounds x="490" y="210" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- GW1: Тип заявки? -->
      <bpmndi:BPMNShape id="Shape_GW_Type" bpmnElement="GW_Type" isMarkerVisible="true">
        <dc:Bounds x="675" y="225" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="660" y="280" width="80" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- T3: Обработать -->
      <bpmndi:BPMNShape id="Shape_Task_Process" bpmnElement="Task_Process">
        <dc:Bounds x="790" y="150" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- T4: Эскалировать -->
      <bpmndi:BPMNShape id="Shape_Task_Escalate" bpmnElement="Task_Escalate">
        <dc:Bounds x="790" y="310" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- GW2: Merge -->
      <bpmndi:BPMNShape id="Shape_GW_Merge" bpmnElement="GW_Merge" isMarkerVisible="true">
        <dc:Bounds x="980" y="225" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- T5: Согласовать -->
      <bpmndi:BPMNShape id="Shape_Task_Approve" bpmnElement="Task_Approve">
        <dc:Bounds x="1095" y="210" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- GW3: Согласовано? -->
      <bpmndi:BPMNShape id="Shape_GW_Approved" bpmnElement="GW_Approved" isMarkerVisible="true">
        <dc:Bounds x="1280" y="225" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1262" y="280" width="86" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- T6: Доработать -->
      <bpmndi:BPMNShape id="Shape_Task_Rework" bpmnElement="Task_Rework">
        <dc:Bounds x="1245" y="340" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- T7: Уведомить (sendTask) -->
      <bpmndi:BPMNShape id="Shape_Task_Notify" bpmnElement="Task_Notify">
        <dc:Bounds x="1395" y="210" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- END: ПОСЛЕ уведомления -->
      <bpmndi:BPMNShape id="Shape_Ev_End" bpmnElement="Ev_End">
        <dc:Bounds x="1567" y="232" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1548" y="273" width="74" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- SEQUENCE FLOW EDGES -->
      <bpmndi:BPMNEdge id="Edge_SF1"  bpmnElement="SF1">
        <di:waypoint x="258" y="250"/><di:waypoint x="310" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_SF2"  bpmnElement="SF2">
        <di:waypoint x="430" y="250"/><di:waypoint x="490" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_SF3"  bpmnElement="SF3">
        <di:waypoint x="610" y="250"/><di:waypoint x="675" y="250"/>
      </bpmndi:BPMNEdge>
      <!-- GW1 → Обработать (вверх) -->
      <bpmndi:BPMNEdge id="Edge_SF4"  bpmnElement="SF4">
        <di:waypoint x="700" y="225"/><di:waypoint x="700" y="190"/><di:waypoint x="790" y="190"/>
        <bpmndi:BPMNLabel><dc:Bounds x="710" y="198" width="70" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <!-- GW1 → Эскалировать (вниз) -->
      <bpmndi:BPMNEdge id="Edge_SF5"  bpmnElement="SF5">
        <di:waypoint x="700" y="275"/><di:waypoint x="700" y="350"/><di:waypoint x="790" y="350"/>
        <bpmndi:BPMNLabel><dc:Bounds x="706" y="318" width="90" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_SF6"  bpmnElement="SF6">
        <di:waypoint x="910" y="190"/><di:waypoint x="1005" y="190"/><di:waypoint x="1005" y="225"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_SF7"  bpmnElement="SF7">
        <di:waypoint x="910" y="350"/><di:waypoint x="1005" y="350"/><di:waypoint x="1005" y="275"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_SF8"  bpmnElement="SF8">
        <di:waypoint x="1030" y="250"/><di:waypoint x="1095" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_SF9"  bpmnElement="SF9">
        <di:waypoint x="1215" y="250"/><di:waypoint x="1280" y="250"/>
      </bpmndi:BPMNEdge>
      <!-- GW3 → Уведомить (Да — прямо вправо) -->
      <bpmndi:BPMNEdge id="Edge_SF10" bpmnElement="SF10">
        <di:waypoint x="1330" y="250"/><di:waypoint x="1395" y="250"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1352" y="232" width="20" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <!-- GW3 → Доработать (Нет — вниз) -->
      <bpmndi:BPMNEdge id="Edge_SF11" bpmnElement="SF11">
        <di:waypoint x="1305" y="275"/><di:waypoint x="1305" y="340"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1312" y="300" width="22" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <!-- Доработать → Согласовать (петля назад) -->
      <bpmndi:BPMNEdge id="Edge_SF12" bpmnElement="SF12">
        <di:waypoint x="1245" y="380"/><di:waypoint x="1155" y="380"/><di:waypoint x="1155" y="290"/>
      </bpmndi:BPMNEdge>
      <!-- Уведомить → Конечное событие -->
      <bpmndi:BPMNEdge id="Edge_SF13" bpmnElement="SF13">
        <di:waypoint x="1515" y="250"/><di:waypoint x="1567" y="250"/>
      </bpmndi:BPMNEdge>

      <!-- POOL: Клиент -->
      <bpmndi:BPMNShape id="Shape_Pool_Client" bpmnElement="Pool_Client" isHorizontal="true">
        <dc:Bounds x="150" y="460" width="1450" height="100"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Ev_ClientSend" bpmnElement="Ev_ClientSend">
        <dc:Bounds x="222" y="492" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="198" y="533" width="84" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Ev_ClientReceive" bpmnElement="Ev_ClientReceive">
        <dc:Bounds x="1567" y="492" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1543" y="533" width="84" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <!-- sequence flow внутри пула клиента (невидимый — просто для валидации) -->
      <bpmndi:BPMNEdge id="Edge_Cl1" bpmnElement="SF_Cl1">
        <di:waypoint x="258" y="510"/><di:waypoint x="1567" y="510"/>
      </bpmndi:BPMNEdge>

      <!-- MESSAGE FLOWS -->
      <!-- Клиент отправляет → стартовое событие компании -->
      <bpmndi:BPMNEdge id="Edge_MF_in" bpmnElement="MF_in">
        <di:waypoint x="240" y="492"/><di:waypoint x="240" y="268"/>
      </bpmndi:BPMNEdge>
      <!-- Task_Notify → Клиент получает ответ -->
      <bpmndi:BPMNEdge id="Edge_MF_out" bpmnElement="MF_out">
        <di:waypoint x="1455" y="290"/><di:waypoint x="1455" y="430"/><di:waypoint x="1585" y="430"/><di:waypoint x="1585" y="492"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
