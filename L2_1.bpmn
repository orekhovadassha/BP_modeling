<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_L2_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <process id="Process_L2_1" name="L2-1: Регистрация и классификация заявки" isExecutable="false">
    <laneSet id="LaneSet_L2_1">
      <lane id="Lane_Op" name="Оператор">
        <flowNodeRef>Ev_Start</flowNodeRef>
        <flowNodeRef>Task_GetForm</flowNodeRef>
        <flowNodeRef>Task_CheckDup</flowNodeRef>
        <flowNodeRef>GW_Dup</flowNodeRef>
        <flowNodeRef>Task_MergeDup</flowNodeRef>
        <flowNodeRef>Ev_EndDup</flowNodeRef>
        <flowNodeRef>Task_CreateTicket</flowNodeRef>
        <flowNodeRef>Task_AutoClassify</flowNodeRef>
        <flowNodeRef>GW_Tagged</flowNodeRef>
        <flowNodeRef>Task_ManualClassify</flowNodeRef>
        <flowNodeRef>GW_MergeCls</flowNodeRef>
        <flowNodeRef>Task_SetPriority</flowNodeRef>
        <flowNodeRef>Ev_End</flowNodeRef>
        <flowNodeRef>Task_AssignRoute</flowNodeRef>
      </lane>
      <lane id="Lane_Sys" name="Платформа для упраления проектами">
        <flowNodeRef>Task_AutoNotify</flowNodeRef>
        <flowNodeRef>Task_LogEvent</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Ev_Start" name="Начать регистрацию" />
    <userTask id="Task_GetForm" name="Получить данные из формы" />
    <serviceTask id="Task_CheckDup" name="Проверить дубликат" />
    <exclusiveGateway id="GW_Dup" name="Дубликат?" />
    <userTask id="Task_MergeDup" name="Объединить с существующей заявкой" />
    <endEvent id="Ev_EndDup" name="Дубликат объединён" />
    <userTask id="Task_CreateTicket" name="Создать тикет" />
    <sendTask id="Task_AutoNotify" name="Отправить авто-уведомление клиенту" />
    <serviceTask id="Task_AutoClassify" name="Классифицировать по ML-тегам" />
    <exclusiveGateway id="GW_Tagged" name="Тег определён?" />
    <userTask id="Task_ManualClassify" name="Классифицировать вручную" />
    <exclusiveGateway id="GW_MergeCls" name="" />
    <userTask id="Task_SetPriority" name="Установить приоритет заявки" />
    <userTask id="Task_AssignRoute" name="Назначить маршрут обработки" />
    <serviceTask id="Task_LogEvent" name="Записать в журнал событий" />
    <endEvent id="Ev_End" name="Заявка классифицирована" />
    <sequenceFlow id="SF1" sourceRef="Ev_Start" targetRef="Task_GetForm" />
    <sequenceFlow id="SF2" sourceRef="Task_GetForm" targetRef="Task_CheckDup" />
    <sequenceFlow id="SF3" sourceRef="Task_CheckDup" targetRef="GW_Dup" />
    <sequenceFlow id="SF4" name="Да" sourceRef="GW_Dup" targetRef="Task_MergeDup" />
    <sequenceFlow id="SF5" name="Нет" sourceRef="GW_Dup" targetRef="Task_CreateTicket" />
    <sequenceFlow id="SF6" sourceRef="Task_MergeDup" targetRef="Ev_EndDup" />
    <sequenceFlow id="SF7" sourceRef="Task_CreateTicket" targetRef="Task_AutoNotify" />
    <sequenceFlow id="SF8" sourceRef="Task_AutoNotify" targetRef="Task_AutoClassify" />
    <sequenceFlow id="SF9" sourceRef="Task_AutoClassify" targetRef="GW_Tagged" />
    <sequenceFlow id="SF10" name="Да" sourceRef="GW_Tagged" targetRef="GW_MergeCls" />
    <sequenceFlow id="SF11" name="Нет" sourceRef="GW_Tagged" targetRef="Task_ManualClassify" />
    <sequenceFlow id="SF12" sourceRef="Task_ManualClassify" targetRef="GW_MergeCls" />
    <sequenceFlow id="SF13" sourceRef="GW_MergeCls" targetRef="Task_SetPriority" />
    <sequenceFlow id="SF14" sourceRef="Task_SetPriority" targetRef="Task_AssignRoute" />
    <sequenceFlow id="SF15" sourceRef="Task_AssignRoute" targetRef="Task_LogEvent" />
    <sequenceFlow id="SF16" sourceRef="Task_LogEvent" targetRef="Ev_End" />
  </process>
